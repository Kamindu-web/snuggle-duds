{% doc %}
  @prompt
    Create a mockup editor for T-shirts, Hoodies. Choose from 10 sample images for adults man. Choose from 10 sample images for women. Choose from 10 sample images for children boys. Choose from 10k sample images for girls. Content should include
    All sample images should be uploaded.
    
    There are
    
    When choosing T-shirts - Two options should be given as adults, children then
    01) Adults - 2 options for men or women
    02) Children - 2 options for girls or boys
    
    Or
    When choosing Hoodies - Two options should be given as adults, children then
    01) Adults - 2 options for men or women
    02) Children - 2 options for girls or boys
    
    Customer needs an option to upload 4 designs. They should include transform controls to change size, position, and rotation within the preview area, separately.
    
    Email me for parts and customer details., Create a mockup editor for T-shirts, Hoodies. Choose from 10 sample images for adults man. Choose from 10 sample images for women. Choose from 10 sample images for children boys. Choose from 10k sample images for girls. Content should include
    All sample images should be uploaded.
    Also, small sample images should be shown after selecting the relevant catagery
    
    There
    
    When choosing T-shirts - Two options should be given as adults, children then
    01) Adults - 2 options for men or women
    02) Children - 2 options for girls or boys
    
    Or
    When choosing Hoodies - Two options should be given as adults, children then
    01) Adults - 2 options for men or women
    02) Children - 2 options for girls or boys
    
    Customer needs an option to upload 4 designs. They should include transform controls to change size, position, and rotation within the preview area, separately.
    
    Email me for parts and customer details.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mockup-editor-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: 8px;
  }

  .ai-mockup-editor-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .ai-mockup-editor-left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-mockup-editor-right-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-mockup-editor-heading-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-editor-section-{{ ai_gen_id }} {
    background: {{ block.settings.section_bg_color }};
    padding: 20px;
    border-radius: 8px;
  }

  .ai-mockup-editor-section-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-editor-button-group-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ai-mockup-editor-button-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .ai-mockup-editor-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-mockup-editor-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.button_active_bg_color }};
    color: {{ block.settings.button_active_text_color }};
    border-color: {{ block.settings.button_active_bg_color }};
  }

  .ai-mockup-editor-thumbnails-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-top: 12px;
  }

  .ai-mockup-editor-thumbnail-{{ ai_gen_id }} {
    aspect-ratio: 1;
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: 4px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    background: white;
  }

  .ai-mockup-editor-thumbnail-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.button_active_bg_color }};
    transform: scale(1.05);
  }

  .ai-mockup-editor-thumbnail-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.button_active_bg_color }};
    border-width: 3px;
  }

  .ai-mockup-editor-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-mockup-editor-preview-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background-color: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-mockup-editor-preview-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-mockup-editor-canvas-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .ai-mockup-editor-design-{{ ai_gen_id }} {
    position: absolute;
    cursor: move;
    pointer-events: auto;
    border: 2px dashed transparent;
    transition: border-color 0.2s;
  }

  .ai-mockup-editor-design-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.button_active_bg_color }};
  }

  .ai-mockup-editor-design-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .ai-mockup-editor-design-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    display: none;
    gap: 4px;
    background: white;
    padding: 4px;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    white-space: nowrap;
  }

  .ai-mockup-editor-design-{{ ai_gen_id }}.selected .ai-mockup-editor-design-controls-{{ ai_gen_id }} {
    display: flex;
  }

  .ai-mockup-editor-control-btn-{{ ai_gen_id }} {
    padding: 4px 8px;
    background: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 3px;
    cursor: pointer;
    font-size: 12px;
  }

  .ai-mockup-editor-control-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg_color }};
  }

  .ai-mockup-editor-upload-area-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .ai-mockup-editor-upload-box-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 1;
    border: 2px dashed {{ block.settings.button_border_color }};
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: white;
    transition: all 0.3s ease;
  }

  .ai-mockup-editor-upload-box-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.button_active_bg_color }};
    background: #f9f9f9;
  }

  .ai-mockup-editor-upload-box-{{ ai_gen_id }} input {
    display: none;
  }

  .ai-mockup-editor-upload-icon-{{ ai_gen_id }} {
    font-size: 32px;
    color: {{ block.settings.button_border_color }};
    margin-bottom: 8px;
  }

  .ai-mockup-editor-upload-text-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    text-align: center;
  }

  .ai-mockup-editor-remove-btn-{{ ai_gen_id }} {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 24px;
    height: 24px;
    background: red;
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 14px;
    display: none;
  }

  .ai-mockup-editor-upload-box-{{ ai_gen_id }}.has-image .ai-mockup-editor-remove-btn-{{ ai_gen_id }} {
    display: block;
  }

  .ai-mockup-editor-submit-{{ ai_gen_id }} {
    padding: 16px 32px;
    background-color: {{ block.settings.submit_button_bg }};
    color: {{ block.settings.submit_button_text_color }};
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    width: 100%;
  }

  .ai-mockup-editor-submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.submit_button_hover_bg }};
  }

  .ai-mockup-editor-form-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-mockup-editor-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-editor-input-{{ ai_gen_id }} {
    padding: 10px;
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: 4px;
    font-size: 14px;
  }

  .ai-mockup-editor-textarea-{{ ai_gen_id }} {
    padding: 10px;
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: 4px;
    font-size: 14px;
    min-height: 80px;
    resize: vertical;
  }

  .ai-mockup-editor-success-{{ ai_gen_id }} {
    padding: 16px;
    background: #d4edda;
    color: #155724;
    border-radius: 4px;
    display: none;
  }

  .ai-mockup-editor-success-{{ ai_gen_id }}.show {
    display: block;
  }

  @media screen and (max-width: 768px) {
    .ai-mockup-editor-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-mockup-editor-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-mockup-editor-thumbnails-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstyle %}

<mockup-editor-{{ ai_gen_id }} class="ai-mockup-editor-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h2 class="ai-mockup-editor-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>

  <div class="ai-mockup-editor-container-{{ ai_gen_id }}">
    <div class="ai-mockup-editor-left-{{ ai_gen_id }}">
      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Choose product type</h3>
        <div class="ai-mockup-editor-button-group-{{ ai_gen_id }}">
          <button class="ai-mockup-editor-button-{{ ai_gen_id }} active" data-product-type="tshirt">T-Shirt</button>
          <button class="ai-mockup-editor-button-{{ ai_gen_id }}" data-product-type="hoodie">Hoodie</button>
          <button class="ai-mockup-editor-button-{{ ai_gen_id }}" data-product-type="other">Other</button>
        </div>
      </div>

      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Choose category</h3>
        <div class="ai-mockup-editor-button-group-{{ ai_gen_id }}">
          <button class="ai-mockup-editor-button-{{ ai_gen_id }} active" data-category="adults">Adults</button>
          <button class="ai-mockup-editor-button-{{ ai_gen_id }}" data-category="children">Children</button>
          <button class="ai-mockup-editor-button-{{ ai_gen_id }}" data-category="otheritem">Otheritem</button>
        </div>
      </div>

      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Choose gender</h3>
        <div class="ai-mockup-editor-button-group-{{ ai_gen_id }}">
          <button class="ai-mockup-editor-button-{{ ai_gen_id }} active" data-gender="men">Men</button>
          <button class="ai-mockup-editor-button-{{ ai_gen_id }}" data-gender="women">Women</button>
        </div>
      </div>

      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Choose mockup</h3>
        <div class="ai-mockup-editor-thumbnails-{{ ai_gen_id }}" data-thumbnail-container></div>
      </div>

      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Upload your designs (up to 4)</h3>
        <div class="ai-mockup-editor-upload-area-{{ ai_gen_id }}">
          {% for i in (1..4) %}
            <div class="ai-mockup-editor-upload-box-{{ ai_gen_id }}" data-upload-index="{{ i }}">
              <input type="file" accept="image/*" data-design-upload="{{ i }}">
              <div class="ai-mockup-editor-upload-icon-{{ ai_gen_id }}">+</div>
              <div class="ai-mockup-editor-upload-text-{{ ai_gen_id }}">Design {{ i }}</div>
              <button class="ai-mockup-editor-remove-btn-{{ ai_gen_id }}" data-remove-design="{{ i }}">×</button>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="ai-mockup-editor-right-{{ ai_gen_id }}">
      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Preview</h3>
        <div class="ai-mockup-editor-preview-{{ ai_gen_id }}">
          {% if block.settings.tshirt_men_1 %}
            <img src="{{ block.settings.tshirt_men_1 | image_url: width: 800 }}" alt="Mockup preview" class="ai-mockup-editor-preview-image-{{ ai_gen_id }}">
          {% else %}
            <div style="color: #999; text-align: center; padding: 20px;">
              <p>Upload mockup images in block settings</p>
            </div>
          {% endif %}
          <div class="ai-mockup-editor-canvas-{{ ai_gen_id }}" data-canvas></div>
        </div>
      </div>

      <div class="ai-mockup-editor-section-{{ ai_gen_id }}">
        <h3 class="ai-mockup-editor-section-title-{{ ai_gen_id }}">Customer details</h3>
        <div class="ai-mockup-editor-form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor-label-{{ ai_gen_id }}">Name</label>
          <input type="text" class="ai-mockup-editor-input-{{ ai_gen_id }}" data-customer-name placeholder="Enter your name">
        </div>
        <div class="ai-mockup-editor-form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor-label-{{ ai_gen_id }}">Email</label>
          <input type="email" class="ai-mockup-editor-input-{{ ai_gen_id }}" data-customer-email placeholder="Enter your email">
        </div>
        <div class="ai-mockup-editor-form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor-label-{{ ai_gen_id }}">Additional notes</label>
          <textarea class="ai-mockup-editor-textarea-{{ ai_gen_id }}" data-customer-notes placeholder="Any special requests or notes"></textarea>
        </div>
      </div>

      <button class="ai-mockup-editor-submit-{{ ai_gen_id }}" data-submit>{{ block.settings.submit_label }}</button>
      <div class="ai-mockup-editor-success-{{ ai_gen_id }}" data-success-message>{{ block.settings.success_message }}</div>
    </div>
  </div>
</mockup-editor-{{ ai_gen_id }}>

<script>
(function() {
  class MockupEditor{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.productType = 'tshirt';
      this.category = 'adults';
      this.gender = 'men';
      this.mockupIndex = 1;
      this.designs = {};
      this.selectedDesign = null;
      this.isDragging = false;
      this.dragStart = { x: 0, y: 0 };
      this.mockupImages = {
        tshirt: {
          adults: {
            men: [
              {% for i in (1..10) %}
                {% assign key = 'tshirt_men_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ],
            women: [
              {% for i in (1..10) %}
                {% assign key = 'tshirt_women_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ]
          },
          children: {
            boys: [
              {% for i in (1..10) %}
                {% assign key = 'tshirt_boys_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ],
            girls: [
              {% for i in (1..10) %}
                {% assign key = 'tshirt_girls_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ]
          }
        },
        hoodie: {
          adults: {
            men: [
              {% for i in (1..10) %}
                {% assign key = 'hoodie_men_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ],
            women: [
              {% for i in (1..10) %}
                {% assign key = 'hoodie_women_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ]
          },
          children: {
            boys: [
              {% for i in (1..10) %}
                {% assign key = 'hoodie_boys_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ],
            girls: [
              {% for i in (1..10) %}
                {% assign key = 'hoodie_girls_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ]
          }
        },
        other: {
          otheritem: {
            cloth: [
              {% for i in (1..10) %}
                {% assign key = 'cloth_adultother_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ],
            cloth: [
              {% for i in (1..10) %}
                {% assign key = 'cloth_kidsother_' | append: i %}
                {% if block.settings[key] %}
                  '{{ block.settings[key] | image_url: width: 800 }}'{% unless forloop.last %},{% endunless %}
                {% else %}
                  ''{% unless forloop.last %},{% endunless %}
                {% endif %}
              {% endfor %}
            ]
          }
        }
      };
    }

    connectedCallback() {
      this.setupEventListeners();
      this.renderThumbnails();
    }

    setupEventListeners() {
      this.querySelectorAll('[data-product-type]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          this.querySelectorAll('[data-product-type]').forEach(b => b.classList.remove('active'));
          e.target.classList.add('active');
          this.productType = e.target.dataset.productType;
          this.mockupIndex = 1;
          this.renderThumbnails();
          this.updatePreview();
        });
      });

      this.querySelectorAll('[data-category]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          this.querySelectorAll('[data-category]').forEach(b => b.classList.remove('active'));
          e.target.classList.add('active');
          this.category = e.target.dataset.category;
          this.mockupIndex = 1;
          this.updateGenderButtons();
          this.renderThumbnails();
          this.updatePreview();
        });
      });

      this.querySelectorAll('[data-gender]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          this.querySelectorAll('[data-gender]').forEach(b => b.classList.remove('active'));
          e.target.classList.add('active');
          this.gender = e.target.dataset.gender;
          this.mockupIndex = 1;
          this.renderThumbnails();
          this.updatePreview();
        });
      });

      this.querySelectorAll('[data-design-upload]').forEach(input => {
        input.addEventListener('change', (e) => {
          const index = e.target.dataset.designUpload;
          const file = e.target.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
              this.addDesign(index, event.target.result);
              const box = e.target.closest('.ai-mockup-editor-upload-box-{{ ai_gen_id }}');
              box.classList.add('has-image');
              box.style.backgroundImage = `url(${event.target.result})`;
              box.style.backgroundSize = 'cover';
              box.style.backgroundPosition = 'center';
              box.querySelector('.ai-mockup-editor-upload-icon-{{ ai_gen_id }}').style.display = 'none';
              box.querySelector('.ai-mockup-editor-upload-text-{{ ai_gen_id }}').style.display = 'none';
            };
            reader.readAsDataURL(file);
          }
        });
      });

      this.querySelectorAll('[data-remove-design]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const index = e.target.dataset.removeDesign;
          this.removeDesign(index);
          const box = e.target.closest('.ai-mockup-editor-upload-box-{{ ai_gen_id }}');
          box.classList.remove('has-image');
          box.style.backgroundImage = '';
          box.querySelector('.ai-mockup-editor-upload-icon-{{ ai_gen_id }}').style.display = 'block';
          box.querySelector('.ai-mockup-editor-upload-text-{{ ai_gen_id }}').style.display = 'block';
          box.querySelector('input').value = '';
        });
      });

      this.querySelectorAll('.ai-mockup-editor-upload-box-{{ ai_gen_id }}').forEach(box => {
        box.addEventListener('click', () => {
          box.querySelector('input').click();
        });
      });

      const submitBtn = this.querySelector('[data-submit]');
      submitBtn.addEventListener('click', () => this.handleSubmit());

      const canvas = this.querySelector('[data-canvas]');
      canvas.addEventListener('mousedown', (e) => this.handleMouseDown(e));
      canvas.addEventListener('mousemove', (e) => this.handleMouseMove(e));
      canvas.addEventListener('mouseup', () => this.handleMouseUp());
      canvas.addEventListener('mouseleave', () => this.handleMouseUp());
    }

    renderThumbnails() {
      const container = this.querySelector('[data-thumbnail-container]');
      container.innerHTML = '';
      
      const genderKey = this.gender;
      const images = this.mockupImages[this.productType][this.category][genderKey];
      
      images.forEach((imageUrl, index) => {
        if (imageUrl) {
          const thumb = document.createElement('div');
          thumb.className = 'ai-mockup-editor-thumbnail-{{ ai_gen_id }}';
          if (index === this.mockupIndex - 1) {
            thumb.classList.add('active');
          }
          
          const img = document.createElement('img');
          img.src = imageUrl;
          img.alt = `Mockup ${index + 1}`;
          thumb.appendChild(img);
          
          thumb.addEventListener('click', () => {
            this.mockupIndex = index + 1;
            this.querySelectorAll('.ai-mockup-editor-thumbnail-{{ ai_gen_id }}').forEach(t => t.classList.remove('active'));
            thumb.classList.add('active');
            this.updatePreview();
          });
          
          container.appendChild(thumb);
        }
      });
    }

    updateGenderButtons() {
      const genderButtons = this.querySelectorAll('[data-gender]');
      if (this.category === 'adults') {
        genderButtons[0].textContent = 'Men';
        genderButtons[0].dataset.gender = 'men';
        genderButtons[1].textContent = 'Women';
        genderButtons[1].dataset.gender = 'women';
        this.gender = 'men';
      } 
    
      
      else {
        genderButtons[0].textContent = 'Boys';
        genderButtons[0].dataset.gender = 'boys';
        genderButtons[1].textContent = 'Girls';
        genderButtons[1].dataset.gender = 'girls';
        this.gender = 'boys';
      }
      genderButtons.forEach(b => b.classList.remove('active'));
      genderButtons[0].classList.add('active');
    }

    updatePreview() {
      const previewImg = this.querySelector('.ai-mockup-editor-preview-image-{{ ai_gen_id }}');
      const genderKey = this.gender;
      const imageUrl = this.mockupImages[this.productType][this.category][genderKey][this.mockupIndex - 1];
      
      if (imageUrl) {
        previewImg.src = imageUrl;
        previewImg.style.display = 'block';
      } else {
        previewImg.style.display = 'none';
      }
    }

    addDesign(index, imageData) {
      const canvas = this.querySelector('[data-canvas]');
      const existingDesign = canvas.querySelector(`[data-design-id="${index}"]`);
      
      if (existingDesign) {
        existingDesign.querySelector('img').src = imageData;
      } else {
        const designEl = document.createElement('div');
        designEl.className = 'ai-mockup-editor-design-{{ ai_gen_id }}';
        designEl.dataset.designId = index;
        designEl.style.width = '100px';
        designEl.style.height = '100px';
        designEl.style.left = '50%';
        designEl.style.top = '50%';
        designEl.style.transform = 'translate(-50%, -50%) rotate(0deg)';
        
        const img = document.createElement('img');
        img.src = imageData;
        designEl.appendChild(img);
        
        const controls = document.createElement('div');
        controls.className = 'ai-mockup-editor-design-controls-{{ ai_gen_id }}';
        controls.innerHTML = `
          <button class="ai-mockup-editor-control-btn-{{ ai_gen_id }}" data-action="rotate-left">↶</button>
          <button class="ai-mockup-editor-control-btn-{{ ai_gen_id }}" data-action="rotate-right">↷</button>
          <button class="ai-mockup-editor-control-btn-{{ ai_gen_id }}" data-action="size-up">+</button>
          <button class="ai-mockup-editor-control-btn-{{ ai_gen_id }}" data-action="size-down">-</button>
        `;
        designEl.appendChild(controls);
        
        designEl.addEventListener('click', (e) => {
          e.stopPropagation();
          this.selectDesign(designEl);
        });
        
        controls.querySelectorAll('button').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            this.handleControlAction(designEl, e.target.dataset.action);
          });
        });
        
        canvas.appendChild(designEl);
        this.designs[index] = {
          element: designEl,
          rotation: 0,
          size: 100
        };
      }
    }

    removeDesign(index) {
      const canvas = this.querySelector('[data-canvas]');
      const designEl = canvas.querySelector(`[data-design-id="${index}"]`);
      if (designEl) {
        designEl.remove();
        delete this.designs[index];
      }
    }

    selectDesign(designEl) {
      this.querySelectorAll('.ai-mockup-editor-design-{{ ai_gen_id }}').forEach(d => d.classList.remove('selected'));
      designEl.classList.add('selected');
      this.selectedDesign = designEl;
    }

    handleControlAction(designEl, action) {
      const index = designEl.dataset.designId;
      const design = this.designs[index];
      
      if (action === 'rotate-left') {
        design.rotation -= 15;
      } else if (action === 'rotate-right') {
        design.rotation += 15;
      } else if (action === 'size-up') {
        design.size = Math.min(design.size + 10, 300);
      } else if (action === 'size-down') {
        design.size = Math.max(design.size - 10, 50);
      }
      
      const currentTransform = designEl.style.transform;
      const translateMatch = currentTransform.match(/translate\(([^,]+),\s*([^)]+)\)/);
      const translateX = translateMatch ? translateMatch[1] : '-50%';
      const translateY = translateMatch ? translateMatch[2] : '-50%';
      
      designEl.style.width = design.size + 'px';
      designEl.style.height = design.size + 'px';
      designEl.style.transform = `translate(${translateX}, ${translateY}) rotate(${design.rotation}deg)`;
    }

    handleMouseDown(e) {
      if (e.target.classList.contains('ai-mockup-editor-design-{{ ai_gen_id }}') || 
          e.target.closest('.ai-mockup-editor-design-{{ ai_gen_id }}')) {
        const designEl = e.target.classList.contains('ai-mockup-editor-design-{{ ai_gen_id }}') ? 
                         e.target : e.target.closest('.ai-mockup-editor-design-{{ ai_gen_id }}');
        this.isDragging = true;
        this.selectedDesign = designEl;
        this.selectDesign(designEl);
        
        const rect = designEl.getBoundingClientRect();
        this.dragStart = {
          x: e.clientX - rect.left,
          y: e.clientY - rect.top
        };
      }
    }

    handleMouseMove(e) {
      if (this.isDragging && this.selectedDesign) {
        const canvas = this.querySelector('[data-canvas]');
        const canvasRect = canvas.getBoundingClientRect();
        
        let newLeft = e.clientX - canvasRect.left - this.dragStart.x;
        let newTop = e.clientY - canvasRect.top - this.dragStart.y;
        
        newLeft = Math.max(0, Math.min(newLeft, canvasRect.width - this.selectedDesign.offsetWidth));
        newTop = Math.max(0, Math.min(newTop, canvasRect.height - this.selectedDesign.offsetHeight));
        
        this.selectedDesign.style.left = newLeft + 'px';
        this.selectedDesign.style.top = newTop + 'px';
        this.selectedDesign.style.transform = this.selectedDesign.style.transform.replace(/translate\([^)]+\)/, 'translate(0, 0)');
      }
    }

    handleMouseUp() {
      this.isDragging = false;
    }

    handleSubmit() {
      const name = this.querySelector('[data-customer-name]').value;
      const email = this.querySelector('[data-customer-email]').value;
      const notes = this.querySelector('[data-customer-notes]').value;
      
      if (!name || !email) {
        alert('Please fill in your name and email');
        return;
      }
      
      const designData = Object.keys(this.designs).map(key => {
        const design = this.designs[key];
        return {
          index: key,
          position: {
            left: design.element.style.left,
            top: design.element.style.top
          },
          rotation: design.rotation,
          size: design.size
        };
      });
      
      const formData = {
        productType: this.productType,
        category: this.category,
        gender: this.gender,
        mockupIndex: this.mockupIndex,
        customerName: name,
        customerEmail: email,
        customerNotes: notes,
        designs: designData
      };
      
      console.log('Form submitted:', formData);
      
      const successMsg = this.querySelector('[data-success-message]');
      successMsg.classList.add('show');
      setTimeout(() => {
        successMsg.classList.remove('show');
      }, 5000);
    }
  }

  customElements.define('mockup-editor-{{ ai_gen_id }}', MockupEditor{{ ai_gen_id }});
})();
</script>

