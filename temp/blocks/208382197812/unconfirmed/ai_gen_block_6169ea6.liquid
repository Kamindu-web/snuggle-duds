{% doc %}
  @prompt
    A T-shirt, a hoodie mockup design is required. One category should contain 1 to 10 sample images in color.
    All sample images should be uploaded.
    
    In it,
    
    When choosing a T-shirt - two options should be given as adults, children, then
    01) Adults - 2 options for men or women
    02) Children - 2 options for women or men
    
    Or
    When choosing a hoodie - two options should be given as adults, children, adults, children, then
    01) Adults - 2 options for men or women
    02) Children - 2 options for women or men
    
    Customer needs an option to upload 4 designs. They should be separate, with transform controls to change size, position and rotation in the preview area.
    
    Send me an email and get the parts, customer details., A T-shirt, a hoodie mockup design is required. One category should contain 1 to 10 sample images in color.
    All sample images should be uploaded.
    
    In it,
    
    When choosing a T-shirt - two options should be given as adults, children, then
    01) Adults - 2 options for men or women
    02) Children - 2 options for women or men
    
    Or
    When choosing a hoodie - two options should be given as adults, children, adults, children, then
    01) Adults - 2 options for men or women
    02) Children - 2 options for women or men
    
    Customer needs an option to upload 4 designs. They should be separate, with transform controls to change size, position and rotation in the preview area.
    
    Send me an email and get the parts, customer details.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mockup-designer-{{ai_gen_id}} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    font-family: {{ block.settings.type_body_font.family }}, sans-serif;
  }

  .ai-mockup-designer__container-{{ai_gen_id}} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-mockup-designer__title-{{ai_gen_id}} {
    font-size: 32px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 30px;
    text-align: center;
  }

  .ai-mockup-designer__layout-{{ai_gen_id}} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .ai-mockup-designer__preview-section-{{ai_gen_id}} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-mockup-designer__preview-container-{{ai_gen_id}} {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background-color: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid {{ block.settings.border_color }};
  }

  .ai-mockup-designer__mockup-image-{{ai_gen_id}} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .ai-mockup-designer__design-layer-{{ai_gen_id}} {
    position: absolute;
    cursor: move;
    user-select: none;
    touch-action: none;
  }

  .ai-mockup-designer__design-image-{{ai_gen_id}} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .ai-mockup-designer__color-selector-{{ai_gen_id}} {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ai-mockup-designer__color-option-{{ai_gen_id}} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 3px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-mockup-designer__color-option-{{ai_gen_id}}:hover {
    transform: scale(1.1);
  }

  .ai-mockup-designer__color-option-{{ai_gen_id}}.active {
    border-color: {{ block.settings.accent_color }};
    box-shadow: 0 0 0 2px {{ block.settings.background_color }}, 0 0 0 4px {{ block.settings.accent_color }};
  }

  .ai-mockup-designer__controls-section-{{ai_gen_id}} {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .ai-mockup-designer__control-group-{{ai_gen_id}} {
    background: white;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-mockup-designer__control-label-{{ai_gen_id}} {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 10px;
  }

  .ai-mockup-designer__select-{{ai_gen_id}} {
    width: 100%;
    padding: 12px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    font-size: 14px;
    background-color: white;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-designer__radio-group-{{ai_gen_id}} {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .ai-mockup-designer__radio-option-{{ai_gen_id}} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-mockup-designer__radio-option-{{ai_gen_id}} input[type="radio"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .ai-mockup-designer__radio-option-{{ai_gen_id}} label {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
  }

  .ai-mockup-designer__upload-area-{{ai_gen_id}} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .ai-mockup-designer__upload-box-{{ai_gen_id}} {
    position: relative;
    aspect-ratio: 1;
    border: 2px dashed {{ block.settings.border_color }};
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background-color: #fafafa;
  }

  .ai-mockup-designer__upload-box-{{ai_gen_id}}:hover {
    border-color: {{ block.settings.accent_color }};
    background-color: #f0f0f0;
  }

  .ai-mockup-designer__upload-box-{{ai_gen_id}}.has-image {
    border-style: solid;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-mockup-designer__upload-icon-{{ai_gen_id}} {
    font-size: 32px;
    color: {{ block.settings.border_color }};
    margin-bottom: 8px;
  }

  .ai-mockup-designer__upload-text-{{ai_gen_id}} {
    font-size: 12px;
    color: #666;
    text-align: center;
  }

  .ai-mockup-designer__upload-preview-{{ai_gen_id}} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 6px;
  }

  .ai-mockup-designer__upload-input-{{ai_gen_id}} {
    display: none;
  }

  .ai-mockup-designer__design-controls-{{ai_gen_id}} {
    display: none;
    flex-direction: column;
    gap: 15px;
  }

  .ai-mockup-designer__design-controls-{{ai_gen_id}}.active {
    display: flex;
  }

  .ai-mockup-designer__slider-group-{{ai_gen_id}} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-mockup-designer__slider-label-{{ai_gen_id}} {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-designer__slider-{{ai_gen_id}} {
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: #e0e0e0;
    outline: none;
    -webkit-appearance: none;
  }

  .ai-mockup-designer__slider-{{ai_gen_id}}::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: {{ block.settings.accent_color }};
    cursor: pointer;
  }

  .ai-mockup-designer__slider-{{ai_gen_id}}::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: {{ block.settings.accent_color }};
    cursor: pointer;
    border: none;
  }

  .ai-mockup-designer__form-section-{{ai_gen_id}} {
    background: white;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-mockup-designer__form-title-{{ai_gen_id}} {
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
  }

  .ai-mockup-designer__form-grid-{{ai_gen_id}} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-bottom: 15px;
  }

  .ai-mockup-designer__form-field-{{ai_gen_id}} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-mockup-designer__form-field-{{ai_gen_id}}.full-width {
    grid-column: 1 / -1;
  }

  .ai-mockup-designer__form-label-{{ai_gen_id}} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-designer__form-input-{{ai_gen_id}} {
    padding: 12px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-designer__form-textarea-{{ai_gen_id}} {
    padding: 12px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    min-height: 100px;
    resize: vertical;
  }

  .ai-mockup-designer__submit-button-{{ai_gen_id}} {
    width: 100%;
    padding: 16px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-mockup-designer__submit-button-{{ai_gen_id}}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-mockup-designer__success-message-{{ai_gen_id}} {
    padding: 15px;
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
    border-radius: 4px;
    margin-bottom: 15px;
    display: none;
  }

  .ai-mockup-designer__success-message-{{ai_gen_id}}.show {
    display: block;
  }

  @media screen and (max-width: 768px) {
    .ai-mockup-designer__layout-{{ai_gen_id}} {
      grid-template-columns: 1fr;
    }

    .ai-mockup-designer__form-grid-{{ai_gen_id}} {
      grid-template-columns: 1fr;
    }

    .ai-mockup-designer__upload-area-{{ai_gen_id}} {
      grid-template-columns: 1fr 1fr;
    }
  }
{% endstyle %}

<mockup-designer-{{ai_gen_id}} class="ai-mockup-designer-{{ai_gen_id}}" {{ block.shopify_attributes }}>
  <div class="ai-mockup-designer__container-{{ai_gen_id}}">
    <h2 class="ai-mockup-designer__title-{{ai_gen_id}}">{{ block.settings.heading }}</h2>

    <div class="ai-mockup-designer__layout-{{ai_gen_id}}">
      <div class="ai-mockup-designer__preview-section-{{ai_gen_id}}">
        <div class="ai-mockup-designer__preview-container-{{ai_gen_id}}" data-preview-container>
          <img class="ai-mockup-designer__mockup-image-{{ai_gen_id}}" data-mockup-image alt="Product mockup">
        </div>

        <div class="ai-mockup-designer__color-selector-{{ai_gen_id}}">
          {% for i in (1..10) %}
            {% assign color_key = 'color_' | append: i %}
            {% assign image_key = 'color_' | append: i | append: '_image' %}
            {% if block.settings[image_key] %}
              <div 
                class="ai-mockup-designer__color-option-{{ai_gen_id}} {% if i == 1 %}active{% endif %}"
                style="background-color: {{ block.settings[color_key] }};"
                data-color-option="{{ i }}"
                data-image-url="{{ block.settings[image_key] | image_url: width: 800 }}"
              ></div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="ai-mockup-designer__controls-section-{{ai_gen_id}}">
        <div class="ai-mockup-designer__control-group-{{ai_gen_id}}">
          <label class="ai-mockup-designer__control-label-{{ai_gen_id}}">Product type</label>
          <select class="ai-mockup-designer__select-{{ai_gen_id}}" data-product-type>
            <option value="tshirt">T-shirt</option>
            <option value="hoodie">Hoodie</option>
          </select>
        </div>

        <div class="ai-mockup-designer__control-group-{{ai_gen_id}}">
          <label class="ai-mockup-designer__control-label-{{ai_gen_id}}">Age group</label>
          <div class="ai-mockup-designer__radio-group-{{ai_gen_id}}">
            <div class="ai-mockup-designer__radio-option-{{ai_gen_id}}">
              <input type="radio" name="age-group-{{ai_gen_id}}" value="adults" id="adults-{{ai_gen_id}}" checked>
              <label for="adults-{{ai_gen_id}}">Adults</label>
            </div>
            <div class="ai-mockup-designer__radio-option-{{ai_gen_id}}">
              <input type="radio" name="age-group-{{ai_gen_id}}" value="children" id="children-{{ai_gen_id}}">
              <label for="children-{{ai_gen_id}}">Children</label>
            </div>
          </div>
        </div>

        <div class="ai-mockup-designer__control-group-{{ai_gen_id}}">
          <label class="ai-mockup-designer__control-label-{{ai_gen_id}}">Gender</label>
          <div class="ai-mockup-designer__radio-group-{{ai_gen_id}}">
            <div class="ai-mockup-designer__radio-option-{{ai_gen_id}}">
              <input type="radio" name="gender-{{ai_gen_id}}" value="men" id="men-{{ai_gen_id}}" checked>
              <label for="men-{{ai_gen_id}}">Men</label>
            </div>
            <div class="ai-mockup-designer__radio-option-{{ai_gen_id}}">
              <input type="radio" name="gender-{{ai_gen_id}}" value="women" id="women-{{ai_gen_id}}">
              <label for="women-{{ai_gen_id}}">Women</label>
            </div>
          </div>
        </div>

        <div class="ai-mockup-designer__control-group-{{ai_gen_id}}">
          <label class="ai-mockup-designer__control-label-{{ai_gen_id}}">Upload designs (up to 4)</label>
          <div class="ai-mockup-designer__upload-area-{{ai_gen_id}}">
            {% for i in (1..4) %}
              <div class="ai-mockup-designer__upload-box-{{ai_gen_id}}" data-upload-box="{{ i }}">
                <div class="ai-mockup-designer__upload-icon-{{ai_gen_id}}">+</div>
                <div class="ai-mockup-designer__upload-text-{{ai_gen_id}}">Design {{ i }}</div>
                <input 
                  type="file" 
                  class="ai-mockup-designer__upload-input-{{ai_gen_id}}" 
                  accept="image/*" 
                  data-design-input="{{ i }}"
                >
              </div>
            {% endfor %}
          </div>
        </div>

        {% for i in (1..4) %}
          <div class="ai-mockup-designer__control-group-{{ai_gen_id}} ai-mockup-designer__design-controls-{{ai_gen_id}}" data-design-controls="{{ i }}">
            <label class="ai-mockup-designer__control-label-{{ai_gen_id}}">Design {{ i }} controls</label>
            
            <div class="ai-mockup-designer__slider-group-{{ai_gen_id}}">
              <div class="ai-mockup-designer__slider-label-{{ai_gen_id}}">
                <span>Size</span>
                <span data-size-value="{{ i }}">100%</span>
              </div>
              <input 
                type="range" 
                class="ai-mockup-designer__slider-{{ai_gen_id}}" 
                min="10" 
                max="200" 
                value="100" 
                data-size-slider="{{ i }}"
              >
            </div>

            <div class="ai-mockup-designer__slider-group-{{ai_gen_id}}">
              <div class="ai-mockup-designer__slider-label-{{ai_gen_id}}">
                <span>Rotation</span>
                <span data-rotation-value="{{ i }}">0°</span>
              </div>
              <input 
                type="range" 
                class="ai-mockup-designer__slider-{{ai_gen_id}}" 
                min="0" 
                max="360" 
                value="0" 
                data-rotation-slider="{{ i }}"
              >
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {%- form 'contact' -%}
      <div class="ai-mockup-designer__form-section-{{ai_gen_id}}">
        <div class="ai-mockup-designer__success-message-{{ai_gen_id}}" data-success-message>
          Thank you! Your design request has been submitted successfully.
        </div>

        <h3 class="ai-mockup-designer__form-title-{{ai_gen_id}}">Your details</h3>

        <input type="hidden" name="contact[subject]" value="Custom Mockup Design Request">
        <input type="hidden" name="contact[design_data]" data-design-data>

        <div class="ai-mockup-designer__form-grid-{{ai_gen_id}}">
          <div class="ai-mockup-designer__form-field-{{ai_gen_id}}">
            <label class="ai-mockup-designer__form-label-{{ai_gen_id}}">Name *</label>
            <input 
              type="text" 
              name="contact[name]" 
              class="ai-mockup-designer__form-input-{{ai_gen_id}}" 
              required
            >
          </div>

          <div class="ai-mockup-designer__form-field-{{ai_gen_id}}">
            <label class="ai-mockup-designer__form-label-{{ai_gen_id}}">Email *</label>
            <input 
              type="email" 
              name="contact[email]" 
              class="ai-mockup-designer__form-input-{{ai_gen_id}}" 
              required
            >
          </div>

          <div class="ai-mockup-designer__form-field-{{ai_gen_id}}">
            <label class="ai-mockup-designer__form-label-{{ai_gen_id}}">Phone</label>
            <input 
              type="tel" 
              name="contact[phone]" 
              class="ai-mockup-designer__form-input-{{ai_gen_id}}"
            >
          </div>

          <div class="ai-mockup-designer__form-field-{{ai_gen_id}}">
            <label class="ai-mockup-designer__form-label-{{ai_gen_id}}">Preferred contact</label>
            <select name="contact[preferred_contact]" class="ai-mockup-designer__select-{{ai_gen_id}}">
              <option value="email">Email</option>
              <option value="phone">Phone</option>
            </select>
          </div>

          <div class="ai-mockup-designer__form-field-{{ai_gen_id}} full-width">
            <label class="ai-mockup-designer__form-label-{{ai_gen_id}}">Additional notes</label>
            <textarea 
              name="contact[body]" 
              class="ai-mockup-designer__form-textarea-{{ai_gen_id}}"
              placeholder="Any special requests or instructions..."
            ></textarea>
          </div>
        </div>

        <button type="submit" class="ai-mockup-designer__submit-button-{{ai_gen_id}}">
          Submit design request
        </button>
      </div>
    {%- endform -%}
  </div>
</mockup-designer-{{ai_gen_id}}>

<script>
(function() {
  class MockupDesigner{{ai_gen_id}} extends HTMLElement {
    constructor() {
      super();
      this.designs = {};
      this.currentColor = 1;
      this.draggedDesign = null;
      this.dragOffset = { x: 0, y: 0 };
    }

    connectedCallback() {
      this.previewContainer = this.querySelector('[data-preview-container]');
      this.mockupImage = this.querySelector('[data-mockup-image]');
      this.colorOptions = this.querySelectorAll('[data-color-option]');
      this.uploadBoxes = this.querySelectorAll('[data-upload-box]');
      this.form = this.querySelector('form');
      this.designDataInput = this.querySelector('[data-design-data]');
      this.successMessage = this.querySelector('[data-success-message]');

      this.initializeColorSelector();
      this.initializeUploadBoxes();
      this.initializeDesignControls();
      this.initializeForm();
      this.loadFirstMockup();
    }

    loadFirstMockup() {
      const firstColor = this.querySelector('[data-color-option="1"]');
      if (firstColor) {
        const imageUrl = firstColor.getAttribute('data-image-url');
        this.mockupImage.src = imageUrl;
      }
    }

    initializeColorSelector() {
      this.colorOptions.forEach(option => {
        option.addEventListener('click', () => {
          this.colorOptions.forEach(opt => opt.classList.remove('active'));
          option.classList.add('active');
          
          const colorIndex = option.getAttribute('data-color-option');
          const imageUrl = option.getAttribute('data-image-url');
          this.mockupImage.src = imageUrl;
          this.currentColor = colorIndex;
        });
      });
    }

    initializeUploadBoxes() {
      this.uploadBoxes.forEach(box => {
        const designIndex = box.getAttribute('data-upload-box');
        const input = box.querySelector(`[data-design-input="${designIndex}"]`);

        box.addEventListener('click', () => input.click());

        input.addEventListener('change', (e) => {
          const file = e.target.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
              this.addDesignToPreview(designIndex, event.target.result);
              box.classList.add('has-image');
              box.innerHTML = `<img src="${event.target.result}" class="ai-mockup-designer__upload-preview-{{ai_gen_id}}" alt="Design ${designIndex}">`;
              
              const controls = this.querySelector(`[data-design-controls="${designIndex}"]`);
              if (controls) {
                controls.classList.add('active');
              }
            };
            reader.readAsDataURL(file);
          }
        });
      });
    }

    addDesignToPreview(index, imageUrl) {
      const existingLayer = this.previewContainer.querySelector(`[data-design-layer="${index}"]`);
      if (existingLayer) {
        existingLayer.remove();
      }

      const layer = document.createElement('div');
      layer.className = 'ai-mockup-designer__design-layer-{{ai_gen_id}}';
      layer.setAttribute('data-design-layer', index);
      layer.style.top = '50%';
      layer.style.left = '50%';
      layer.style.width = '100px';
      layer.style.height = '100px';
      layer.style.transform = 'translate(-50%, -50%)';

      const img = document.createElement('img');
      img.src = imageUrl;
      img.className = 'ai-mockup-designer__design-image-{{ai_gen_id}}';
      layer.appendChild(img);

      this.previewContainer.appendChild(layer);

      this.designs[index] = {
        element: layer,
        size: 100,
        rotation: 0,
        x: 50,
        y: 50
      };

      this.initializeDragging(layer, index);
    }

    initializeDragging(layer, index) {
      const startDrag = (e) => {
        e.preventDefault();
        this.draggedDesign = index;
        
        const rect = this.previewContainer.getBoundingClientRect();
        const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
        
        this.dragOffset.x = clientX - rect.left - (this.designs[index].x * rect.width / 100);
        this.dragOffset.y = clientY - rect.top - (this.designs[index].y * rect.height / 100);
      };

      const drag = (e) => {
        if (this.draggedDesign !== index) return;
        
        const rect = this.previewContainer.getBoundingClientRect();
        const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
        
        const x = ((clientX - rect.left - this.dragOffset.x) / rect.width) * 100;
        const y = ((clientY - rect.top - this.dragOffset.y) / rect.height) * 100;
        
        this.designs[index].x = Math.max(0, Math.min(100, x));
        this.designs[index].y = Math.max(0, Math.min(100, y));
        
        this.updateDesignTransform(index);
      };

      const endDrag = () => {
        this.draggedDesign = null;
      };

      layer.addEventListener('mousedown', startDrag);
      layer.addEventListener('touchstart', startDrag);
      document.addEventListener('mousemove', drag);
      document.addEventListener('touchmove', drag);
      document.addEventListener('mouseup', endDrag);
      document.addEventListener('touchend', endDrag);
    }

    initializeDesignControls() {
      for (let i = 1; i <= 4; i++) {
        const sizeSlider = this.querySelector(`[data-size-slider="${i}"]`);
        const rotationSlider = this.querySelector(`[data-rotation-slider="${i}"]`);
        const sizeValue = this.querySelector(`[data-size-value="${i}"]`);
        const rotationValue = this.querySelector(`[data-rotation-value="${i}"]`);

        if (sizeSlider) {
          sizeSlider.addEventListener('input', (e) => {
            const value = e.target.value;
            sizeValue.textContent = value + '%';
            if (this.designs[i]) {
              this.designs[i].size = value;
              this.updateDesignTransform(i);
            }
          });
        }

        if (rotationSlider) {
          rotationSlider.addEventListener('input', (e) => {
            const value = e.target.value;
            rotationValue.textContent = value + '°';
            if (this.designs[i]) {
              this.designs[i].rotation = value;
              this.updateDesignTransform(i);
            }
          });
        }
      }
    }

    updateDesignTransform(index) {
      const design = this.designs[index];
      if (!design) return;

      const size = design.size;
      design.element.style.width = size + 'px';
      design.element.style.height = size + 'px';
      design.element.style.left = design.x + '%';
      design.element.style.top = design.y + '%';
      design.element.style.transform = `translate(-50%, -50%) rotate(${design.rotation}deg)`;
    }

    initializeForm() {
      this.form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const productType = this.querySelector('[data-product-type]').value;
        const ageGroup = this.querySelector('input[name="age-group-{{ai_gen_id}}"]:checked').value;
        const gender = this.querySelector('input[name="gender-{{ai_gen_id}}"]:checked').value;
        
        const designData = {
          productType: productType,
          ageGroup: ageGroup,
          gender: gender,
          color: this.currentColor,
          designs: []
        };

        Object.keys(this.designs).forEach(key => {
          const design = this.designs[key];
          designData.designs.push({
            designNumber: key,
            size: design.size + '%',
            rotation: design.rotation + '°',
            positionX: design.x.toFixed(1) + '%',
            positionY: design.y.toFixed(1) + '%'
          });
        });

        this.designDataInput.value = JSON.stringify(designData, null, 2);
        
        this.form.submit();
        
        this.successMessage.classList.add('show');
        setTimeout(() => {
          this.successMessage.classList.remove('show');
        }, 5000);
      });
    }
  }

  customElements.define('mockup-designer-{{ai_gen_id}}', MockupDesigner{{ai_gen_id}});
})();
</script>

