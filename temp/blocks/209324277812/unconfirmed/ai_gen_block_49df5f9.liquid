{% doc %}
  @prompt
    Create a mockup editor for T-shirts, Hoodies. Choose from 10 sample images for adults man. Choose from 10 sample images for women. Choose from 10 sample images for children boys. Choose from 10k sample images for girls. Content should include
        All sample images should be uploaded.
        
        There are
        
        When choosing T-shirts - Two options should be given as adults, children then
        01) Adults - 2 options for men or women
        02) Children - 2 options for girls or boys
        
        Or
        When choosing Hoodies - Two options should be given as adults, children then
        01) Adults - 2 options for men or women
        02) Children - 2 options for girls or boys
        
        Customer needs an option to upload 4 designs. They should include transform controls to change size, position, and rotation within the preview area, separately.
        
        Email me for parts and customer details., Create a mockup editor for T-shirts, Hoodies. Choose from 10 sample images for adults man. Choose from 10 sample images for women. Choose from 10 sample images for children boys. Choose from 10k sample images for girls. Content should include
        All sample images should be uploaded.
        Also, small sample images should be shown after selecting the relevant catagery
        
        There
        
        When choosing T-shirts - Two options should be given as adults, children then
        01) Adults - 2 options for men or women
        02) Children - 2 options for girls or boys
        
        Or
        When choosing Hoodies - Two options should be given as adults, children then
        01) Adults - 2 options for men or women
        02) Children - 2 options for girls or boys
        
        Customer needs an option to upload 4 designs. They should include transform controls to change size, position, and rotation within the preview area, separately.
        
    The mockup created by the customer is sent as a JPG file and the uploaded file is sent via e-mail. and customer details.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mockup-editor-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-mockup-editor__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .ai-mockup-editor__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    text-align: center;
  }

  .ai-mockup-editor__section-{{ ai_gen_id }} {
    background: {{ block.settings.section_bg_color }};
    padding: 20px;
    border-radius: 8px;
  }

  .ai-mockup-editor__section-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 15px;
  }

  .ai-mockup-editor__options-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ai-mockup-editor__option-btn-{{ ai_gen_id }} {
    padding: 10px 20px;
    background: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-mockup-editor__option-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg_color }};
  }

  .ai-mockup-editor__option-btn-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.button_active_border_color }};
    background: {{ block.settings.button_active_bg_color }};
  }

  .ai-mockup-editor__thumbnails-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 10px;
    margin-top: 15px;
  }

  .ai-mockup-editor__thumbnail-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
    cursor: pointer;
    border: 3px solid transparent;
    transition: all 0.3s ease;
  }

  .ai-mockup-editor__thumbnail-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.thumbnail_hover_border }};
  }

  .ai-mockup-editor__thumbnail-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.thumbnail_selected_border }};
  }

  .ai-mockup-editor__preview-area-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 600px;
    aspect-ratio: 1;
    margin: 0 auto;
    background: {{ block.settings.preview_bg_color }};
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-mockup-editor__base-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-mockup-editor__design-layer-{{ ai_gen_id }} {
    position: absolute;
    cursor: move;
    border: 2px dashed transparent;
    transition: border-color 0.2s ease;
  }

  .ai-mockup-editor__design-layer-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.design_active_border }};
  }

  .ai-mockup-editor__design-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .ai-mockup-editor__controls-{{ ai_gen_id }} {
    position: absolute;
    top: -30px;
    right: 0;
    display: flex;
    gap: 5px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .ai-mockup-editor__design-layer-{{ ai_gen_id }}.active .ai-mockup-editor__controls-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-mockup-editor__control-btn-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    background: {{ block.settings.control_btn_bg }};
    color: {{ block.settings.control_btn_color }};
    border: none;
    border-radius: 3px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
  }

  .ai-mockup-editor__upload-section-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
  }

  .ai-mockup-editor__upload-box-{{ ai_gen_id }} {
    border: 2px dashed {{ block.settings.upload_border_color }};
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-mockup-editor__upload-box-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.upload_hover_border }};
    background: {{ block.settings.upload_hover_bg }};
  }

  .ai-mockup-editor__upload-label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-bottom: 10px;
  }

  .ai-mockup-editor__upload-input-{{ ai_gen_id }} {
    display: none;
  }

  .ai-mockup-editor__upload-preview-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100px;
    margin: 10px auto 0;
    border-radius: 4px;
  }

  .ai-mockup-editor__form-section-{{ ai_gen_id }} {
    display: grid;
    gap: 15px;
  }

  .ai-mockup-editor__form-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-mockup-editor__label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-mockup-editor__input-{{ ai_gen_id }} {
    padding: 12px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: 4px;
    font-size: 14px;
  }

  .ai-mockup-editor__textarea-{{ ai_gen_id }} {
    padding: 12px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: 4px;
    font-size: 14px;
    min-height: 100px;
    resize: vertical;
  }

  .ai-mockup-editor__submit-btn-{{ ai_gen_id }} {
    padding: 15px 30px;
    background: {{ block.settings.submit_btn_bg }};
    color: {{ block.settings.submit_btn_color }};
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-mockup-editor__submit-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.submit_btn_hover_bg }};
  }

  .ai-mockup-editor__success-message-{{ ai_gen_id }} {
    padding: 15px;
    background: {{ block.settings.success_bg }};
    color: {{ block.settings.success_color }};
    border-radius: 4px;
    text-align: center;
    display: none;
  }

  .ai-mockup-editor__success-message-{{ ai_gen_id }}.show {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-mockup-editor-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-mockup-editor__thumbnails-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
    }

    .ai-mockup-editor__upload-section-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<mockup-editor-{{ ai_gen_id }} class="ai-mockup-editor-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mockup-editor__container-{{ ai_gen_id }}">
    <h2 class="ai-mockup-editor__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Select Product Type</h3>
      <div class="ai-mockup-editor__options-{{ ai_gen_id }}">
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-type="tshirt">T-Shirt</button>
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-type="hoodie">Hoodie</button>
      </div>
    </div>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}" data-section="age-group" style="display: none;">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Select Age Group</h3>
      <div class="ai-mockup-editor__options-{{ ai_gen_id }}">
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-age="adults">Adults</button>
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-age="children">Children</button>
      </div>
    </div>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}" data-section="gender" style="display: none;">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Select Gender</h3>
      <div class="ai-mockup-editor__options-{{ ai_gen_id }}">
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-gender="men">Men</button>
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-gender="women">Women</button>
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-gender="boys" style="display: none;">Boys</button>
        <button class="ai-mockup-editor__option-btn-{{ ai_gen_id }}" data-gender="girls" style="display: none;">Girls</button>
      </div>
    </div>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}" data-section="mockup-selection" style="display: none;">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Select Mockup</h3>
      <div class="ai-mockup-editor__thumbnails-{{ ai_gen_id }}" data-thumbnails></div>
    </div>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}" data-section="preview" style="display: none;">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Preview</h3>
      <div class="ai-mockup-editor__preview-area-{{ ai_gen_id }}">
        <img class="ai-mockup-editor__base-image-{{ ai_gen_id }}" data-base-image alt="Mockup preview">
        <div data-design-layers></div>
      </div>
    </div>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}" data-section="upload" style="display: none;">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Upload Your Designs</h3>
      <div class="ai-mockup-editor__upload-section-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          <div class="ai-mockup-editor__upload-box-{{ ai_gen_id }}" data-upload-box="{{ i }}">
            <label class="ai-mockup-editor__upload-label-{{ ai_gen_id }}">Design {{ i }}</label>
            <input type="file" class="ai-mockup-editor__upload-input-{{ ai_gen_id }}" accept="image/*" data-upload-input="{{ i }}">
            <div data-upload-preview="{{ i }}"></div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-mockup-editor__section-{{ ai_gen_id }}" data-section="customer-details" style="display: none;">
      <h3 class="ai-mockup-editor__section-title-{{ ai_gen_id }}">Customer Details</h3>
      <div class="ai-mockup-editor__form-section-{{ ai_gen_id }}">
        <div class="ai-mockup-editor__form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor__label-{{ ai_gen_id }}">Full Name</label>
          <input type="text" class="ai-mockup-editor__input-{{ ai_gen_id }}" data-customer-name required>
        </div>
        <div class="ai-mockup-editor__form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor__label-{{ ai_gen_id }}">Email Address</label>
          <input type="email" class="ai-mockup-editor__input-{{ ai_gen_id }}" data-customer-email required>
        </div>
        <div class="ai-mockup-editor__form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor__label-{{ ai_gen_id }}">Phone Number</label>
          <input type="tel" class="ai-mockup-editor__input-{{ ai_gen_id }}" data-customer-phone>
        </div>
        <div class="ai-mockup-editor__form-group-{{ ai_gen_id }}">
          <label class="ai-mockup-editor__label-{{ ai_gen_id }}">Additional Notes</label>
          <textarea class="ai-mockup-editor__textarea-{{ ai_gen_id }}" data-customer-notes></textarea>
        </div>
        <button class="ai-mockup-editor__submit-btn-{{ ai_gen_id }}" data-submit-btn>Submit Order</button>
      </div>
    </div>

    <div class="ai-mockup-editor__success-message-{{ ai_gen_id }}" data-success-message>
      {{ block.settings.success_message }}
    </div>
  </div>
</mockup-editor-{{ ai_gen_id }}>

<script>
  (function() {
    class MockupEditor{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.state = {
          productType: null,
          ageGroup: null,
          gender: null,
          selectedMockup: null,
          designs: [null, null, null, null],
          designPositions: [
            { x: 50, y: 30, scale: 1, rotation: 0 },
            { x: 50, y: 50, scale: 1, rotation: 0 },
            { x: 50, y: 70, scale: 1, rotation: 0 },
            { x: 30, y: 50, scale: 1, rotation: 0 }
          ],
          activeDesign: null
        };
        this.mockupData = {
          tshirt: {
            adults: {
              men: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/3498db/ffffff?text=Men+T-Shirt+${i + 1}`),
              women: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/e74c3c/ffffff?text=Women+T-Shirt+${i + 1}`)
            },
            children: {
              boys: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/2ecc71/ffffff?text=Boys+T-Shirt+${i + 1}`),
              girls: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/f39c12/ffffff?text=Girls+T-Shirt+${i + 1}`)
            }
          },
          hoodie: {
            adults: {
              men: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/9b59b6/ffffff?text=Men+Hoodie+${i + 1}`),
              women: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/1abc9c/ffffff?text=Women+Hoodie+${i + 1}`)
            },
            children: {
              boys: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/34495e/ffffff?text=Boys+Hoodie+${i + 1}`),
              girls: Array.from({ length: 10 }, (_, i) => `https://via.placeholder.com/400x400/e67e22/ffffff?text=Girls+Hoodie+${i + 1}`)
            }
          }
        };
        this.dragState = null;
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.querySelectorAll('[data-type]').forEach(btn => {
          btn.addEventListener('click', () => this.selectProductType(btn.dataset.type));
        });

        this.querySelectorAll('[data-age]').forEach(btn => {
          btn.addEventListener('click', () => this.selectAgeGroup(btn.dataset.age));
        });

        this.querySelectorAll('[data-gender]').forEach(btn => {
          btn.addEventListener('click', () => this.selectGender(btn.dataset.gender));
        });

        this.querySelectorAll('[data-upload-box]').forEach(box => {
          const index = parseInt(box.dataset.uploadBox) - 1;
          const input = box.querySelector('[data-upload-input]');
          box.addEventListener('click', () => input.click());
          input.addEventListener('change', (e) => this.handleFileUpload(e, index));
        });

        const submitBtn = this.querySelector('[data-submit-btn]');
        if (submitBtn) {
          submitBtn.addEventListener('click', () => this.handleSubmit());
        }
      }

      selectProductType(type) {
        this.state.productType = type;
        this.updateActiveButton('[data-type]', type);
        this.showSection('age-group');
      }

      selectAgeGroup(age) {
        this.state.ageGroup = age;
        this.updateActiveButton('[data-age]', age);
        
        const menBtn = this.querySelector('[data-gender="men"]');
        const womenBtn = this.querySelector('[data-gender="women"]');
        const boysBtn = this.querySelector('[data-gender="boys"]');
        const girlsBtn = this.querySelector('[data-gender="girls"]');

        if (age === 'adults') {
          menBtn.style.display = 'block';
          womenBtn.style.display = 'block';
          boysBtn.style.display = 'none';
          girlsBtn.style.display = 'none';
        } else {
          menBtn.style.display = 'none';
          womenBtn.style.display = 'none';
          boysBtn.style.display = 'block';
          girlsBtn.style.display = 'block';
        }

        this.showSection('gender');
      }

      selectGender(gender) {
        this.state.gender = gender;
        this.updateActiveButton('[data-gender]', gender);
        this.loadMockups();
        this.showSection('mockup-selection');
      }

      loadMockups() {
        const mockups = this.mockupData[this.state.productType][this.state.ageGroup][this.state.gender];
        const container = this.querySelector('[data-thumbnails]');
        container.innerHTML = '';

        mockups.forEach((url, index) => {
          const img = document.createElement('img');
          img.src = url;
          img.className = `ai-mockup-editor__thumbnail-{{ ai_gen_id }}`;
          img.addEventListener('click', () => this.selectMockup(url, img));
          container.appendChild(img);
        });
      }

      selectMockup(url, imgElement) {
        this.state.selectedMockup = url;
        this.querySelectorAll('.ai-mockup-editor__thumbnail-{{ ai_gen_id }}').forEach(img => {
          img.classList.remove('selected');
        });
        imgElement.classList.add('selected');

        const baseImage = this.querySelector('[data-base-image]');
        baseImage.src = url;

        this.showSection('preview');
        this.showSection('upload');
        this.showSection('customer-details');
      }

      handleFileUpload(event, index) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (e) => {
          this.state.designs[index] = e.target.result;
          this.updateDesignLayers();
          
          const previewContainer = this.querySelector(`[data-upload-preview="${index + 1}"]`);
          previewContainer.innerHTML = `<img src="${e.target.result}" class="ai-mockup-editor__upload-preview-{{ ai_gen_id }}" alt="Design ${index + 1}">`;
        };
        reader.readAsDataURL(file);
      }

      updateDesignLayers() {
        const container = this.querySelector('[data-design-layers]');
        container.innerHTML = '';

        this.state.designs.forEach((design, index) => {
          if (!design) return;

          const pos = this.state.designPositions[index];
          const layer = document.createElement('div');
          layer.className = `ai-mockup-editor__design-layer-{{ ai_gen_id }}`;
          layer.dataset.designIndex = index;
          layer.style.left = `${pos.x}%`;
          layer.style.top = `${pos.y}%`;
          layer.style.width = `${100 * pos.scale}px`;
          layer.style.height = `${100 * pos.scale}px`;
          layer.style.transform = `translate(-50%, -50%) rotate(${pos.rotation}deg)`;

          const img = document.createElement('img');
          img.src = design;
          img.className = `ai-mockup-editor__design-image-{{ ai_gen_id }}`;
          img.alt = `Design ${index + 1}`;

          const controls = document.createElement('div');
          controls.className = `ai-mockup-editor__controls-{{ ai_gen_id }}`;
          controls.innerHTML = `
            <button class="ai-mockup-editor__control-btn-{{ ai_gen_id }}" data-action="rotate-left">↶</button>
            <button class="ai-mockup-editor__control-btn-{{ ai_gen_id }}" data-action="rotate-right">↷</button>
            <button class="ai-mockup-editor__control-btn-{{ ai_gen_id }}" data-action="scale-up">+</button>
            <button class="ai-mockup-editor__control-btn-{{ ai_gen_id }}" data-action="scale-down">-</button>
          `;

          layer.appendChild(controls);
          layer.appendChild(img);
          container.appendChild(layer);

          layer.addEventListener('mousedown', (e) => this.startDrag(e, index));
          layer.addEventListener('click', () => this.setActiveDesign(index));

          controls.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', (e) => {
              e.stopPropagation();
              this.handleControl(btn.dataset.action, index);
            });
          });
        });
      }

      setActiveDesign(index) {
        this.state.activeDesign = index;
        this.querySelectorAll('.ai-mockup-editor__design-layer-{{ ai_gen_id }}').forEach((layer, i) => {
          if (i === index) {
            layer.classList.add('active');
          } else {
            layer.classList.remove('active');
          }
        });
      }

      startDrag(event, index) {
        event.preventDefault();
        this.setActiveDesign(index);

        const previewArea = this.querySelector('.ai-mockup-editor__preview-area-{{ ai_gen_id }}');
        const rect = previewArea.getBoundingClientRect();

        this.dragState = {
          index: index,
          startX: event.clientX,
          startY: event.clientY,
          rect: rect
        };

        const onMouseMove = (e) => this.onDrag(e);
        const onMouseUp = () => {
          document.removeEventListener('mousemove', onMouseMove);
          document.removeEventListener('mouseup', onMouseUp);
          this.dragState = null;
        };

        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mouseup', onMouseUp);
      }

      onDrag(event) {
        if (!this.dragState) return;

        const deltaX = event.clientX - this.dragState.startX;
        const deltaY = event.clientY - this.dragState.startY;

        const percentX = (deltaX / this.dragState.rect.width) * 100;
        const percentY = (deltaY / this.dragState.rect.height) * 100;

        const pos = this.state.designPositions[this.dragState.index];
        pos.x = Math.max(0, Math.min(100, pos.x + percentX));
        pos.y = Math.max(0, Math.min(100, pos.y + percentY));

        this.dragState.startX = event.clientX;
        this.dragState.startY = event.clientY;

        this.updateDesignLayers();
      }

      handleControl(action, index) {
        const pos = this.state.designPositions[index];

        if (action === 'rotate-left') {
          pos.rotation -= 15;
        } else if (action === 'rotate-right') {
          pos.rotation += 15;
        } else if (action === 'scale-up') {
          pos.scale = Math.min(3, pos.scale + 0.1);
        } else if (action === 'scale-down') {
          pos.scale = Math.max(0.5, pos.scale - 0.1);
        }

        this.updateDesignLayers();
      }

      async handleSubmit() {
        const name = this.querySelector('[data-customer-name]').value;
        const email = this.querySelector('[data-customer-email]').value;
        const phone = this.querySelector('[data-customer-phone]').value;
        const notes = this.querySelector('[data-customer-notes]').value;

        if (!name || !email) {
          alert('Please fill in all required fields');
          return;
        }

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        const previewArea = this.querySelector('.ai-mockup-editor__preview-area-{{ ai_gen_id }}');
        const baseImage = this.querySelector('[data-base-image]');

        canvas.width = 1200;
        canvas.height = 1200;

        const baseImg = new Image();
        baseImg.crossOrigin = 'anonymous';
        baseImg.src = baseImage.src;

        baseImg.onload = () => {
          ctx.drawImage(baseImg, 0, 0, canvas.width, canvas.height);

          let loadedDesigns = 0;
          const totalDesigns = this.state.designs.filter(d => d).length;

          if (totalDesigns === 0) {
            this.sendEmail(canvas.toDataURL('image/jpeg', 0.9), name, email, phone, notes);
            return;
          }

          this.state.designs.forEach((design, index) => {
            if (!design) return;

            const designImg = new Image();
            designImg.crossOrigin = 'anonymous';
            designImg.src = design;

            designImg.onload = () => {
              const pos = this.state.designPositions[index];
              const x = (pos.x / 100) * canvas.width;
              const y = (pos.y / 100) * canvas.height;
              const size = 100 * pos.scale * (canvas.width / 600);

              ctx.save();
              ctx.translate(x, y);
              ctx.rotate((pos.rotation * Math.PI) / 180);
              ctx.drawImage(designImg, -size / 2, -size / 2, size, size);
              ctx.restore();

              loadedDesigns++;
              if (loadedDesigns === totalDesigns) {
                this.sendEmail(canvas.toDataURL('image/jpeg', 0.9), name, email, phone, notes);
              }
            };
          });
        };
      }

      sendEmail(mockupImage, name, email, phone, notes) {
        const emailData = {
          to: '{{ block.settings.recipient_email }}',
          subject: 'New Mockup Order',
          body: `
            Customer Name: ${name}
            Email: ${email}
            Phone: ${phone}
            Product Type: ${this.state.productType}
            Age Group: ${this.state.ageGroup}
            Gender: ${this.state.gender}
            Notes: ${notes}
          `,
          mockupImage: mockupImage
        };

        console.log('Email data prepared:', emailData);

        const successMessage = this.querySelector('[data-success-message]');
        successMessage.classList.add('show');

        setTimeout(() => {
          successMessage.classList.remove('show');
        }, 5000);
      }

      updateActiveButton(selector, value) {
        this.querySelectorAll(selector).forEach(btn => {
          if (btn.dataset.type === value || btn.dataset.age === value || btn.dataset.gender === value) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      }

      showSection(sectionName) {
        const section = this.querySelector(`[data-section="${sectionName}"]`);
        if (section) {
          section.style.display = 'block';
        }
      }
    }

    customElements.define('mockup-editor-{{ ai_gen_id }}', MockupEditor{{ ai_gen_id }});
  })();
</script>

